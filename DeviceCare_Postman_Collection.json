          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": "{{base_url}}/department",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"ICU\",\n  \"location\": \"Floor 2 - Block A\"\n}"
            }
          }
        },
        {
          "name": "Add Department - Duplicate (should fail 409)",
