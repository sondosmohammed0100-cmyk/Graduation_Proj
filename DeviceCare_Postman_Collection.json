            "url": "{{base_url}}/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"Fname\": \"Sara\",\n  \"Lname\": \"Ahmed\",\n  \"email\": \"sara.staff@hospital.org\",\n  \"password\": \"password123\",\n  \"cpassword\": \"password123\",\n  \"role\": \"Staff\"\n}"
