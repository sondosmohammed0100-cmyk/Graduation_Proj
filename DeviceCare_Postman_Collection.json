        },
        {
          "name": "Get Maintenance Record By Id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": "{{base_url}}/maintenance/{{maintenance_id}}"
          }
        },
        {
          "name": "Update Maintenance - Completed (Technician)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
