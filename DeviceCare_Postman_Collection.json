    {
      "name": "05 - Maintenance Requests",
      "item": [
        {
          "name": "Create Request (Staff)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.Request) pm.collectionVariables.set('maint_req_id', res.Request._id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{staff_token}}" }
            ],
            "url": "{{base_url}}/maintenance-request",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"issueDescription\": \"Ventilator is making abnormal noise and showing error code E-401\",\n  \"priority\": \"Emergency\",\n  \"device\": \"{{device_id}}\"\n}"
            }
          }
        },
        {
          "name": "Create Request - Non Staff (should fail 403)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tech_token}}" }
