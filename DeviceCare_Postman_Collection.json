{
  "info": {
    "name": "DeviceCare CMMS API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",        "value": "http://localhost:3000/api" },
    { "key": "admin_token",     "value": "" },
    { "key": "bioeng_token",    "value": "" },
    { "key": "tech_token",      "value": "" },
    { "key": "staff_token",     "value": "" },
    { "key": "device_id",       "value": "" },
    { "key": "department_id",   "value": "" },
    { "key": "contract_id",     "value": "" },
    { "key": "maint_req_id",    "value": "" },
    { "key": "work_order_id",   "value": "" },
    { "key": "maintenance_id",  "value": "" },
    { "key": "reset_token",     "value": "" }
  ],
  "item": [

