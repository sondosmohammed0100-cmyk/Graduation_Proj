    {
      "name": "07 - Maintenance Records",
      "item": [
        {
          "name": "Create Maintenance Record (Technician)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.Maintenance) pm.collectionVariables.set('maintenance_id', res.Maintenance._id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tech_token}}" }
            ],
            "url": "{{base_url}}/maintenance",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"Corrective\",\n  \"maintenanceDate\": \"2026-04-28\",\n  \"status\": \"In Progress\",\n  \"notes\": \"Replaced motor fan and cleaned filters\",\n  \"device\": \"{{device_id}}\",\n  \"workOrder\": \"{{work_order_id}}\"\n}"
            }
          }
        },
        {
          "name": "Create Maintenance - Non Technician (should fail 403)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{staff_token}}" }
            ],
